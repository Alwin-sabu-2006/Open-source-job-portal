<%- include('header') %>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">Analytics Dashboard</h1>
        <a href="/admin/dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="row">
        <!-- User Roles Chart -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0">User Distribution by Role</h5>
                </div>
                <div class="card-body">
                    <canvas id="userRolesChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Job Status Chart -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Job Postings Status</h5>
                </div>
                <div class="card-body">
                    <canvas id="jobStatusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js Library -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Parse the data passed from the server
    const chartData = <%- JSON.stringify(chartData) %>;

    // 1. User Roles Chart (Doughnut)
    const userCtx = document.getElementById('userRolesChart').getContext('2d');
    new Chart(userCtx, {
        type: 'doughnut',
        data: {
            labels: chartData.userRoles.labels,
            datasets: [{
                data: chartData.userRoles.data,
                backgroundColor: [
                    '#4f46e5', // Indigo
                    '#10b981', // Emerald
                    '#f59e0b', // Amber
                    '#ef4444', // Red
                    '#6366f1'  // Violet
                ],
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom',
                },
                title: {
                    display: true,
                    text: 'Registered Users by Role'
                }
            }
        }
    });

    // 2. Job Status Chart (Bar)
    const jobCtx = document.getElementById('jobStatusChart').getContext('2d');
    new Chart(jobCtx, {
        type: 'bar',
        data: {
            labels: chartData.jobStatuses.labels,
            datasets: [{
                label: 'Number of Jobs',
                data: chartData.jobStatuses.data,
                backgroundColor: [
                    '#10b981', // Approved (Green)
                    '#f59e0b', // Pending (Amber)
                    '#ef4444'  // Rejected (Red)
                ],
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            },
            plugins: {
                legend: {
                    display: false
                },
                title: {
                    display: true,
                    text: 'Job Postings by Status'
                }
            }
        }
    });
</script>

<%- include('footer') %>