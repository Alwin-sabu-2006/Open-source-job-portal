<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }
        .hero-container {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            background: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2070&auto=format&fit=crop') no-repeat center center;
            background-size: cover;
            position: relative;
        }
        .hero-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(40, 40, 70, 0.6); /* Dark overlay */
        }
        .hero-content {
            position: relative;
            z-index: 1;
            animation: fadeInSlideUp 1s ease-out forwards;
        }
        @keyframes fadeInSlideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .hero-content h1 {
            font-size: 5rem;
            font-weight: 700;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
        }
        .hero-content .lead {
            font-size: 1.5rem;
            font-weight: 300;
            max-width: 600px;
            margin: 1rem auto 2rem auto;
        }
    </style>
</head>
<body>
    <div class="hero-container">
        <div class="hero-content">
            <h1 class="display-1">Careerio</h1>
            <p class="lead mb-4">Your gateway to a world of opportunities. Find your dream job today.</p>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a href="/auth/login" class="btn btn-primary btn-lg px-4 gap-3">Login</a>
                <a href="/auth/register" class="btn btn-outline-light btn-lg px-4">Register</a>
            </div>
        </div>
    </div>
</body>
</html>