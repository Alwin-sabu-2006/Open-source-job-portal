<%- include('header') %>

<style>
    body {
        /* A subtle, professional gradient background */
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }
</style>

<div class="container mt-4">
    <div class="p-4 mb-4 bg-light rounded-3 shadow-sm">
        <h1 class="display-5">Welcome, <%= user.name %>!</h1>
        <p class="lead">Manage your existing listings below or post a new one to find the perfect candidate.</p>
        <hr class="my-4">
        <a href="/jobs/create" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle-fill"></i> Post a New Job
        </a>
        <button type="button" class="btn btn-outline-primary btn-lg ms-2 position-relative">
            <i class="bi bi-envelope-fill"></i> Messages
            <% if (typeof unreadMessageCount !== 'undefined' && unreadMessageCount > 0) { %>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                    <%= unreadMessageCount %>
                    <span class="visually-hidden">unread messages</span>
                </span>
            <% } %>
        </button>
    </div>

    <% if (jobs.length > 0) { %>
        <div class="list-group">
            <% jobs.forEach(job => { %>
                <div class="list-group-item list-group-item-action flex-column align-items-start">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">
                            <%= job.title %>
                            <% if (job.status === 'pending') { %>
                                <span class="badge bg-warning text-dark">Pending Review</span>
                            <% } else if (job.status === 'approved') { %>
                                <span class="badge bg-success">Approved</span>
                            <% } else if (job.status === 'rejected') { %>
                                <span class="badge bg-danger">Rejected</span>
                            <% } %>
                        </h5>
                        <small>Posted on: <%= new Date(job.createdAt).toLocaleDateString() %></small>
                    </div>
                    <p class="mb-1 text-muted"><%= job.location %> | <%= job.jobType %></p>
                    <small>
                        <a href="/jobs/<%= job._id %>" class="btn btn-sm btn-outline-info">View</a>
                        <a href="/jobs/<%= job._id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form action="/jobs/<%= job._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this job?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </small>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center p-5 border rounded bg-white">
            <i class="bi bi-cloud-plus-fill" style="font-size: 4rem; color: #6c757d;"></i>
            <h4 class="mt-3">No Jobs Posted Yet</h4>
            <p class="text-muted">Click the "Post a New Job" button above to get started.</p>
        </div>
    <% } %>
</div>

<%- include('footer') %>