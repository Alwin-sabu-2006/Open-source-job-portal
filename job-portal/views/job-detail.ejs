<%- include('header') %>

<style>
    .job-detail-header {
        background-color: #f8f9fa;
        padding: 2rem;
        border-radius: 12px;
    }
    .job-meta span {
        margin-right: 1.5rem;
        color: #6c757d;
        font-size: 0.95rem;
    }
    .job-description {
        line-height: 1.8;
        white-space: pre-wrap; /* Respects newlines and spaces in the description */
    }
</style>

<div class="container my-5">
    <div class="mb-3">
        <% if (typeof user !== 'undefined' && user && user.role === 'employer') { %>
            <a href="/jobs/dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        <% } else if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
            <a href="/admin/dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Admin Dashboard
            </a>
        <% } else { %>
            <a href="/jobs" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Jobs
            </a>
        <% } %>
    </div>
    <div class="row">
        <div class="col-lg-8">
            <!-- Job Detail Header -->
            <div class="job-detail-header mb-4">
                <h1 class="display-6 fw-bold"><%= job.title %></h1>
                <h2 class="h5 text-muted mb-3"><%= job.employer ? job.employer.name : 'Confidential' %></h2>
                <div class="job-meta d-flex flex-wrap">
                    <span><i class="bi bi-geo-alt-fill me-2"></i><%= job.location %></span>
                    <span><i class="bi bi-briefcase-fill me-2"></i><%= job.jobType %></span>
                    <% if (job.salary) { %>
                        <span><i class="bi bi-cash-stack me-2"></i><%= job.salary %></span>
                    <% } %>
                </div>
            </div>

            <!-- Job Description -->
            <div class="card border-0">
                <div class="card-body p-4">
                    <h3 class="h5 mb-3">Job Description</h3>
                    <p class="job-description"><%= job.description %></p>
                </div>
            </div>
        </div>

        <!-- Action Sidebar -->
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body text-center p-4">
                    <% if (user && user.role === 'job_seeker') { %> 
                        <% if (hasApplied) { %>
                            <!-- Show "Applied" status -->
                            <% if (typeof applicationStatus !== 'undefined' && applicationStatus === 'Accepted') { %>
                                <div class="alert alert-success mb-3">
                                    <h4 class="alert-heading">Congratulations!</h4>
                                    <p>Your application has been <strong>Accepted</strong>.</p>
                                    <hr>
                                    <p class="mb-0">The employer will contact you shortly regarding the next steps.</p>
                                </div>
                            <% } else { %>
                                <div class="alert alert-info mb-3">
                                    <strong>Status:</strong> <%= typeof applicationStatus !== 'undefined' && applicationStatus ? applicationStatus : 'Submitted' %>
                                </div>
                            <% } %>
                            <button class="btn btn-success btn-lg w-100" disabled>
                                <i class="bi bi-check-circle-fill me-2"></i>Applied
                            </button>
                            <p class="small text-muted mt-2">You have already applied for this position.</p>
                        <% } else { %>
                            <!-- Show Apply button -->
                            <form action="/jobs/<%= job._id %>/apply" method="POST" enctype="multipart/form-data">
                                <div class="mb-3 text-start">
                                    <label for="resume" class="form-label">Upload Resume</label>
                                    <input type="file" class="form-control" id="resume" name="resume" required>
                                </div>
                                <div class="mb-3 text-start">
                                    <label for="coverLetter" class="form-label">Cover Letter</label>
                                    <textarea class="form-control" id="coverLetter" name="coverLetter" rows="3"></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-lg w-100">Apply Now</button>
                            </form>
                        <% } %>
                    <% } else if (user) { %>
                        <!-- Message for employers/admins -->
                        <% if (user.role === 'employer' && job.employer && user.id === job.employer._id.toString()) { %>
                            <a href="/jobs/<%= job._id %>/applicants" class="btn btn-primary btn-lg w-100">View Applicants</a>
                            <p class="small text-muted mt-2">Review applications for this job.</p>
                        <% } %>
                    <% } else { %>
                        <!-- Message for logged-out users -->
                        <p class="text-muted">Please <a href="/auth/login">log in</a> or <a href="/auth/register">register</a> as a job seeker to apply.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('footer') %>