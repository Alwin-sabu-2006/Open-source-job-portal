<%- include('header') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">User Details</h2>
        <button onclick="history.back()" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Go Back
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0"><%= userDetails.name %> (<%= userDetails.role.replace('_', ' ') %>)</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Email:</strong> <%= userDetails.email %></p>
                    <p><strong>Role:</strong> <span class="badge bg-info"><%= userDetails.role.replace('_', ' ') %></span></p>
                    <p><strong>Account Status:</strong> 
                        <% if (userDetails.verificationStatus === 'verified') { %>
                            <span class="badge bg-success">Verified</span>
                        <% } else if (userDetails.verificationStatus === 'pending') { %>
                            <span class="badge bg-warning">Pending</span>
                        <% } else if (userDetails.verificationStatus === 'frozen') { %>
                            <span class="badge bg-secondary">Frozen</span>
                        <% } else { %>
                            <span class="badge bg-danger">Rejected</span>
                        <% } %>
                    </p>
                    <p><strong>Joined On:</strong> <%= userDetails.createdAt ? userDetails.createdAt.toDateString() : 'N/A' %></p>
                </div>

                <% if (userDetails.role === 'employer' && userDetails.verificationStatus === 'pending') { %>
                    <div class="col-md-6 align-self-center">
                        <div class="card bg-light p-3">
                            <h6 class="card-title">Admin Actions</h6>
                            <p class="card-text small">Review this employer's information and take action.</p>
                            <div class="d-flex">
                                <form action="/admin/employers/<%= userDetails._id %>/approve" method="POST" class="me-2">
                                    <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                </form>
                                <form action="/admin/employers/<%= userDetails._id %>/reject" method="POST">
                                    <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% } else if (userDetails.role === 'employer') { %> 
                <div class="col-md-6">
                    <h5>Company Information</h5>
                    <hr>
                    <p><strong>Company Name:</strong> <%= userDetails.companyName || 'N/A' %></p>
                    <p><strong>Company Website:</strong> 
                        <% if (userDetails.companyWebsite) { %>
                            <a href="<%= userDetails.companyWebsite %>" target="_blank"><%= userDetails.companyWebsite %></a>
                        <% } else { %>
                            N/A
                        <% } %>
                    </p>
                    <p><strong>Job Title:</strong> <%= userDetails.jobTitle || 'N/A' %></p>
                    <p><strong>Contact Phone:</strong> <%= userDetails.contactPhone || 'N/A' %></p>
                    <p><strong>Company Address:</strong></p>
                    <p><%= userDetails.companyAddress || 'N/A' %></p>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Admin Actions Card -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Administrator Actions</h5>
        </div>
        <div class="card-body d-flex flex-wrap gap-2 align-items-center">
            <% if (userDetails.verificationStatus === 'verified') { %>
                <!-- Freeze Button -->
                <form action="/admin/users/<%= userDetails._id %>/freeze" method="POST">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-snow"></i> Freeze Account
                    </button>
                </form>
                <small class="text-muted ms-2">Freezing will prevent the user from logging in.</small>
            <% } else if (userDetails.verificationStatus === 'frozen') { %>
                <!-- Unfreeze Button -->
                <form action="/admin/users/<%= userDetails._id %>/unfreeze" method="POST">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-unlock"></i> Unfreeze Account
                    </button>
                </form>
                <small class="text-muted ms-2">Unfreezing will restore the user's access.</small>
            <% } %>

            <div class="ms-auto">
                <form action="/admin/users/<%= userDetails._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to permanently delete this user?');">
                    <button type="submit" class="btn btn-outline-danger ms-2"><i class="bi bi-trash"></i> Delete</button>
                </form>
            </div>
        </div>
        <div class="card-footer bg-transparent border-top-0">
             <small class="text-danger"><strong>Warning:</strong> Deleting a user is permanent.</small>
        </div>
    </div>

    <% if (userDetails.role === 'employer' && jobs.length > 0) { %>
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Jobs Posted by <%= userDetails.companyName %></h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th>Date Posted</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% jobs.forEach(job => { %>
                        <tr>
                            <td><a href="/jobs/<%= job._id %>"><%= job.title %></a></td>
                            <td><%= job.location %></td>
                            <td>
                                <% if (job.status === 'approved') { %>
                                    <span class="badge bg-success">Approved</span>
                                <% } else if (job.status === 'pending') { %>
                                    <span class="badge bg-warning">Pending</span>
                                <% } else { %>
                                    <span class="badge bg-danger">Rejected</span>
                                <% } %>
                            </td>
                            <td><%= job.createdAt.toDateString() %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <% } else if (userDetails.role === 'employer') { %>
        <div class="alert alert-info mt-4">This employer has not posted any jobs yet.</div>
    <% } %>

</div>

<%- include('footer') %>