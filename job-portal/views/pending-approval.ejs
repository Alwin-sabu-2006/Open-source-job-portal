<%- include('header') %>

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="p-5 bg-light rounded-3 shadow-sm">
                <h1 class="display-4">Thank you, <%= typeof name !== 'undefined' ? name : 'for registering' %>!</h1>
                <p class="lead mt-3">Your account has been submitted for review. To ensure the quality of our platform, this process typically takes <strong>1-3 business days.</strong></p>
                <hr class="my-4">
                <p>You will be notified via email once your account is approved. You can then log in to post jobs and manage your listings.</p>
                <% if (user) { %>
                    <a class="btn btn-secondary mt-3" href="/auth/logout">Logout</a>
                <% } else { %>
                    <a class="btn btn-primary mt-3" href="/auth/login">Back to Login</a>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('footer') %>